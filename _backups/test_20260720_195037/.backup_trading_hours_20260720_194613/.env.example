# ============================================================
#  MemeCoin Sniper — متغیرهای محیطی (رازها)
#  این فایل را کپی کنید:  cp .env.example .env
#  هیچوقت فایل .env را در git قرار ندهید
# ============================================================

# --- صرافی متمرکز (اختیاری — بدون آن فقط DEX فعال است) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- تلگرام (اختیاری — اعلان سیگنال‌ها به گروه/چت خصوصی) ---
# برای گرفتن توکن: با @BotFather ربات بسازید
# برای گرفتن chat_id: ابتدا ربات را استارت کنید و به
#   https://api.telegram.org/bot<TOKEN>/getUpdates بروید
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- امنیت داشبورد (اختیاری) ---
# اگر خالی باشد، داشبورد بدون رمز عبور باز می‌شود
WEB_AUTH_TOKEN=

# --- LLM دستیار (اختیاری — ارتقاء دستیار با مدل زبانی) ---
# برای استفاده از LLM در دستیار، use_llm را در config.yaml فعال کنید
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1

# --- عملکرد پایتون ---
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
